{
  "manifest_version": 3,
  "name": "WebBridge",
  "version": "1.0.1",
  "description": "Turn any website into an MCP server. Record API traffic, bridge browser auth to Claude tools — no code required.",
  "permissions": [
    "debugger",
    "cookies",
    "scripting",
    "nativeMessaging",
    "tabs",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "WebBridge"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
